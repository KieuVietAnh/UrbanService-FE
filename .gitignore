# ===================================
# UrbanMind Monorepo .gitignore
# ===================================

# ──────────────────────────────────
# Dependencies
# ──────────────────────────────────
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz
.history/
# ──────────────────────────────────
# Build Outputs
# ──────────────────────────────────
dist/
build/
out/
.output/
.next/
.nuxt/
swagger.json
# ──────────────────────────────────
# Environment Variables
# !! NEVER commit .env files !!
# ──────────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local

# ──────────────────────────────────
# Vite / React (apps/web)
# ──────────────────────────────────
.vite/
vite.config.*.timestamp-*

# ──────────────────────────────────
# Expo / React Native (apps/mobile)
# ──────────────────────────────────
.expo/
.expo-shared/
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.orig.*
web-build/
android/
ios/

# Metro bundler
.metro-health-check*

# ──────────────────────────────────
# Logs
# ──────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ──────────────────────────────────
# OS Generated Files
# ──────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ──────────────────────────────────
# IDE / Editor
# ──────────────────────────────────
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp

# ──────────────────────────────────
# Testing
# ──────────────────────────────────
coverage/
.nyc_output/
*.snap

# ──────────────────────────────────
# TypeScript
# ──────────────────────────────────
*.tsbuildinfo

# ──────────────────────────────────
# Misc
# ──────────────────────────────────
*.local
.cache/
.turbo/
