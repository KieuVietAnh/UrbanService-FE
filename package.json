{
  "name": "urbanmind-monorepo",
  "version": "1.0.0",
  "packageManager": "pnpm@10.34.2",
  "private": true,
  "description": "UrbanMind Capstone Project Monorepo",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm --dir apps/web dev",
    "dev:web": "pnpm --dir apps/web dev",
    "build:web": "pnpm --dir apps/web build",
    "dev:mobile": "pnpm --dir apps/mobile start",
    "test:e2e": "pnpm --dir apps/web test:e2e",
    "test:e2e:ui": "pnpm --dir apps/web test:e2e:ui",
    "test:e2e:report": "pnpm --dir apps/web test:e2e:report"
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  }
}
